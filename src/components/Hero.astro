---
// Hero — full-frame photo background with red headline + opt-in form on the right.
// Matches the current allstarbjj.com hero pattern exactly.
import LeadForm from './LeadForm.astro';

export interface Props {
  eyebrow?: string;
  headline?: string;
  sub?: string;
  bgImage?: string;
  bgPosition?: string; // CSS object-position for hero photo framing
  showForm?: boolean;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow,
  headline = "Union's Best Martial Arts School",
  sub,
  bgImage = '/images/hero-team.jpg',
  bgPosition = '50% 50%',
  showForm = true,
  ctaHref = '/trial/',
  ctaLabel = 'Claim Your Free 2-Week Trial',
} = Astro.props;
---

<section class="relative bg-brand-black text-white overflow-hidden">
  <!-- Full-frame background photo with dark overlay for legibility.
       If the local hero-team.jpg isn't saved yet, falls back to a working WP image. -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={bgImage}
      alt=""
      class="w-full h-full object-cover"
      style={`object-position: ${bgPosition}`}
      loading="eager"
      fetchpriority="high"
    />
    <!-- Vertical-only gradient — keeps photo faces visible up top, gives headline contrast at the bottom. -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/45 to-black/10"></div>
  </div>

  <div class="container-page relative z-10 py-16 md:py-24 lg:py-28 grid lg:grid-cols-5 gap-10 items-center">
    <!-- Left: headline + sub copy (matches current site word-for-word) -->
    <div class="lg:col-span-3">
      {eyebrow && (
        <div class="inline-block mb-5 px-3 py-1 bg-brand-navy text-white text-[11px] font-bold uppercase tracking-[0.2em] rounded">
          {eyebrow}
        </div>
      )}
      <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl uppercase font-black leading-[0.95] mb-6 text-brand-red">
        {headline}
      </h1>
      <p class="text-base md:text-lg text-white/95 mb-4 max-w-2xl leading-relaxed">
        {sub || `Find out why so many people in Union turn to AllStar Martial Arts for their martial arts training. Parents just like you have discovered how to maximize their child's potential and accelerate their development! Request more information or get started today with our exclusive online only offer!`}
      </p>
      <p class="text-base md:text-lg text-white/95 font-bold leading-relaxed">
        Union members have seen improvements in as little as 7 days!
      </p>
      {!showForm && (
        <div class="flex flex-wrap gap-3 mt-6">
          <a href={ctaHref} class="btn-red">{ctaLabel}</a>
          <a href="tel:+19086412769" class="btn-outline">📞 (908) 641-2769</a>
        </div>
      )}
    </div>

    <!-- Right: red opt-in box -->
    {showForm && (
      <div class="lg:col-span-2 flex justify-center lg:justify-end">
        <LeadForm />
      </div>
    )}
  </div>
</section>
