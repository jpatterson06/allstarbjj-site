---
// Hero — full-width photo background with dark overlay, headline on left, opt-in form on right.
// Matches the "headline + lead-capture form" pattern from the current allstarbjj.com.
import LeadForm from './LeadForm.astro';

export interface Props {
  eyebrow?: string;
  headline: string;
  sub: string;
  bgImage?: string;
  showForm?: boolean;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow = "Union, NJ · Family-owned since 2011",
  headline,
  sub,
  bgImage = 'https://allstarbjj.com/wp-content/uploads/sites/861/2025/09/Adult-BJJ-1.jpg',
  showForm = true,
  ctaHref = '/trial/',
  ctaLabel = 'Claim Your Free 2-Week Trial',
} = Astro.props;
---

<section class="relative bg-brand-black text-white overflow-hidden">
  <!-- Background image with dark overlay -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={bgImage}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/65 to-black/40"></div>
  </div>

  <div class="container-page relative z-10 py-16 md:py-24 lg:py-32 grid lg:grid-cols-5 gap-10 items-center">
    <!-- Left: headline + sub + CTAs -->
    <div class="lg:col-span-3">
      {eyebrow && (
        <div class="inline-block mb-5 px-3 py-1 bg-brand-navy text-white text-[11px] font-bold uppercase tracking-[0.2em] rounded">
          {eyebrow}
        </div>
      )}
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl uppercase font-black leading-[1.05] mb-5 text-white">
        {headline}
      </h1>
      <p class="text-base md:text-lg text-gray-100 mb-7 max-w-2xl leading-relaxed">
        {sub}
      </p>
      {!showForm && (
        <div class="flex flex-wrap gap-3">
          <a href={ctaHref} class="btn-red">{ctaLabel}</a>
          <a href="tel:+19086412769" class="btn-outline">📞 (908) 641-2769</a>
        </div>
      )}
      <div class="mt-6 flex items-center gap-2 text-sm text-gray-200">
        <span class="text-brand-gold">★★★★★</span>
        <span>Trusted by hundreds of NJ families since 2011</span>
      </div>
    </div>

    <!-- Right: lead-capture form -->
    {showForm && (
      <div class="lg:col-span-2 flex justify-center lg:justify-end">
        <LeadForm variant="hero" />
      </div>
    )}
  </div>
</section>
