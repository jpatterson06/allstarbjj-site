---
// Program card — photo on top, label + blurb below. Used in homepage grid + service overview pages.
export interface Props {
  title: string;
  ages: string;
  href: string;
  blurb: string;
  image: string;
}
const { title, ages, href, blurb, image } = Astro.props;
---

<a href={href} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-all border border-brand-gray-mid hover:border-brand-navy">
  <!-- Image -->
  <div class="aspect-[4/3] bg-brand-gray-light overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>
  <!-- Body -->
  <div class="p-5 md:p-6">
    <div class="text-xs font-bold uppercase tracking-widest text-brand-navy mb-1">{ages}</div>
    <h3 class="font-display text-2xl md:text-3xl text-brand-black mb-3 group-hover:text-brand-navy transition-colors">{title}</h3>
    <p class="text-sm text-brand-gray leading-relaxed mb-4">{blurb}</p>
    <div class="text-sm font-bold text-brand-navy uppercase tracking-wider inline-flex items-center gap-1">
      Learn more <span class="group-hover:translate-x-1 transition-transform">→</span>
    </div>
  </div>
</a>
