---
// Lead opt-in form — captures First Name, Last Name, Phone, Email, Program.
// Uses Netlify Forms (data-netlify="true") so submissions auto-email Jamal +
// land in the Netlify dashboard. Once command center wires the lead webhook,
// this same form will also POST into Supabase to trigger the AI funnel.
export interface Props {
  variant?: 'hero' | 'standalone';
  programLocked?: string; // pre-fill program when used on a service page
}
const { variant = 'hero', programLocked } = Astro.props;
const isHero = variant === 'hero';
---

<form
  name="lead-trial"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/thanks/"
  class={`${isHero ? 'bg-white text-brand-black' : 'bg-brand-gray-light text-brand-black'} rounded-lg shadow-2xl p-6 md:p-7 w-full max-w-md`}
>
  <!-- Netlify Forms hidden fields -->
  <input type="hidden" name="form-name" value="lead-trial" />
  <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

  <div class="text-center mb-5">
    <div class="font-display text-3xl md:text-4xl uppercase font-black text-brand-navy leading-none">Claim Your<br/>Free 2-Week Trial</div>
    <div class="text-xs text-brand-gray uppercase tracking-widest mt-2">No commitment · No pressure</div>
  </div>

  <div class="space-y-3">
    <div class="grid grid-cols-2 gap-3">
      <input
        type="text" name="first_name" required placeholder="First Name"
        class="w-full px-4 py-3 border border-brand-gray-mid rounded-md text-sm focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
      />
      <input
        type="text" name="last_name" required placeholder="Last Name"
        class="w-full px-4 py-3 border border-brand-gray-mid rounded-md text-sm focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
      />
    </div>
    <input
      type="tel" name="phone" required placeholder="Mobile Phone"
      class="w-full px-4 py-3 border border-brand-gray-mid rounded-md text-sm focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
    />
    <input
      type="email" name="email" required placeholder="Email"
      class="w-full px-4 py-3 border border-brand-gray-mid rounded-md text-sm focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
    />
    {programLocked ? (
      <input type="hidden" name="program_of_interest" value={programLocked} />
    ) : (
      <select
        name="program_of_interest" required
        class="w-full px-4 py-3 border border-brand-gray-mid rounded-md text-sm bg-white focus:border-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-navy/20"
      >
        <option value="">I'm interested in...</option>
        <option value="Adult BJJ">Adult Brazilian Jiu Jitsu</option>
        <option value="Adult Muay Thai">Adult Muay Thai</option>
        <option value="Adult MMA">Adult MMA</option>
        <option value="Lions">Kids — Lions (ages 7-13)</option>
        <option value="Cubs">Kids — Cubs (ages 4-7)</option>
        <option value="Birthday Parties">Birthday Party</option>
        <option value="Not sure yet">Not sure yet — help me pick</option>
      </select>
    )}
  </div>

  <button
    type="submit"
    class="w-full mt-4 bg-brand-red hover:bg-red-700 text-white font-bold uppercase tracking-wider text-base py-4 rounded-md transition-colors"
  >
    Claim My Free Trial →
  </button>

  <div class="text-[11px] text-brand-gray text-center mt-3 leading-snug">
    By submitting, you agree to receive SMS from All Star MMA. Reply STOP to opt
    out. Msg & data rates may apply. <a href="/privacy-policy/" class="underline">Privacy</a>.
  </div>
</form>
