---
// Hero opt-in form — modeled after the current allstarbjj.com red box.
// On program pages (programLocked set), the header is "[Program] / TRY FREE 2-WEEK TRIAL".
// Elsewhere (homepage, trial pages), the generic "VIEW OUR SCHEDULE..." header shows.
// Wired to Netlify Forms — auto-emails Jamal + lands in the Netlify dashboard.
export interface Props {
  programLocked?: string; // pre-fill program when used on a service page
}
const { programLocked } = Astro.props;

// Display label for the program (used in the header on program pages).
const programDisplay: Record<string, string> = {
  'Adult BJJ': 'Brazilian Jiu Jitsu',
  'Adult Muay Thai': 'Muay Thai',
  'Adult MMA': 'MMA',
  'Lions': 'Kids — Lions',
  'Cubs': 'Preschool — Cubs',
};
const headerLabel = programLocked ? programDisplay[programLocked] ?? programLocked : null;
---

<form
  name="lead-trial"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/thanks/"
  class="bg-brand-red text-white rounded-md shadow-2xl p-6 md:p-7 w-full max-w-sm"
>
  <!-- Netlify Forms hidden fields -->
  <input type="hidden" name="form-name" value="lead-trial" />
  <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

  <div class="text-center mb-5">
    {headerLabel ? (
      <>
        <div class="font-display text-2xl md:text-3xl uppercase font-black leading-tight">{headerLabel}</div>
        <div class="font-display text-lg md:text-xl uppercase font-black leading-tight mt-1">Try Free 2-Week Trial</div>
      </>
    ) : (
      <>
        <div class="font-display text-xl md:text-2xl uppercase font-black leading-tight">View Our Schedule</div>
        <div class="font-display text-xl md:text-2xl uppercase font-black leading-tight">And Gain Access To Our</div>
        <div class="font-display text-xl md:text-2xl uppercase font-black leading-tight">Exclusive Web Special</div>
      </>
    )}
  </div>

  <div class="space-y-3">
    <input
      type="text" name="first_name" required placeholder="First Name"
      class="w-full px-4 py-3 bg-white text-brand-black rounded-md text-sm placeholder:text-brand-gray focus:outline-none focus:ring-2 focus:ring-brand-gold"
    />
    <input
      type="text" name="last_name" required placeholder="Last Name"
      class="w-full px-4 py-3 bg-white text-brand-black rounded-md text-sm placeholder:text-brand-gray focus:outline-none focus:ring-2 focus:ring-brand-gold"
    />
    <input
      type="email" name="email" required placeholder="Email Address"
      class="w-full px-4 py-3 bg-white text-brand-black rounded-md text-sm placeholder:text-brand-gray focus:outline-none focus:ring-2 focus:ring-brand-gold"
    />
    <input
      type="tel" name="phone" required placeholder="Mobile Phone"
      class="w-full px-4 py-3 bg-white text-brand-black rounded-md text-sm placeholder:text-brand-gray focus:outline-none focus:ring-2 focus:ring-brand-gold"
    />
    {programLocked ? (
      <input type="hidden" name="program_of_interest" value={programLocked} />
    ) : (
      <select
        name="program_of_interest" required
        class="w-full px-4 py-3 bg-white text-brand-black rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-brand-gold"
      >
        <option value="">▼ Select A Program</option>
        <option value="Adult BJJ">Brazilian Jiu Jitsu</option>
        <option value="Adult Muay Thai">Muay Thai</option>
        <option value="Adult MMA">MMA</option>
        <option value="Lions">Kids — Lions (ages 7-13)</option>
        <option value="Cubs">Preschool — Cubs (ages 4-6)</option>
        <option value="Not sure yet">Not sure yet — help me pick</option>
      </select>
    )}
  </div>

  <button
    type="submit"
    class="w-full mt-4 bg-brand-black hover:bg-brand-navy text-white font-bold uppercase tracking-wider text-base py-4 rounded-md transition-colors flex items-center justify-center gap-2"
  >
    <span class="bg-white text-brand-black rounded-full w-6 h-6 inline-flex items-center justify-center text-xs">→</span>
    Get Started Today
  </button>

  <div class="text-[11px] text-white/90 text-center mt-3 leading-snug">
    By opting in, you agree to receive periodic text messages & emails from
    AllStar Martial Arts. Your information will never be shared. Reply STOP
    to cancel. Standard rates may apply. View our
    <a href="/terms-of-service/" class="underline">Terms of Service</a> &
    <a href="/privacy-policy/" class="underline">Privacy Policy</a>.
  </div>
</form>
