---
// Inner-page hero — smaller than homepage hero, but same vibe.
// Red headline + dark photo background + optional opt-in form on the right.
import LeadForm from './LeadForm.astro';

export interface Props {
  eyebrow?: string;
  headline: string;
  sub?: string;
  bgImage?: string;
  bgPosition?: string; // CSS object-position (e.g. "30% 25%") to keep faces in frame
  showForm?: boolean;
  programLocked?: string; // pre-selects the program in the lead form
}

const {
  eyebrow,
  headline,
  sub,
  bgImage = 'https://allstarbjj.com/wp-content/uploads/sites/861/2025/09/Adult-BJJ-1.jpg',
  bgPosition = '50% 50%',
  showForm = true,
  programLocked,
} = Astro.props;
---

<section class="relative bg-brand-black text-white overflow-hidden">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={bgImage}
      alt=""
      class="w-full h-full object-cover"
      style={`object-position: ${bgPosition}`}
      loading="eager"
      fetchpriority="high"
    />
    <!-- Vertical gradient only — keeps photo faces visible up top, gives headline
         contrast at the bottom where the H1 sits. -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/45 to-black/10"></div>
  </div>

  <div class={`container-page relative z-10 py-12 md:py-20 ${showForm ? 'grid lg:grid-cols-5 gap-10 items-center' : ''}`}>
    <div class={showForm ? 'lg:col-span-3' : 'max-w-3xl'}>
      {eyebrow && (
        <div class="inline-block mb-4 px-3 py-1 bg-brand-navy text-white text-[11px] font-bold uppercase tracking-[0.2em] rounded">
          {eyebrow}
        </div>
      )}
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl uppercase font-black leading-[0.95] mb-5 text-brand-red">
        {headline}
      </h1>
      {sub && (
        <p class="text-base md:text-lg text-white/95 leading-relaxed max-w-2xl">{sub}</p>
      )}
    </div>

    {showForm && (
      <div class="lg:col-span-2 flex justify-center lg:justify-end">
        <LeadForm programLocked={programLocked} />
      </div>
    )}
  </div>
</section>
