---
// Bottom-of-page CTA band — used to close the deal at the end of every page
export interface Props {
  headline?: string;
  sub?: string;
  ctaHref?: string;
  ctaLabel?: string;
}
const {
  headline = 'Ready to start?',
  sub = 'First 2 weeks are on us. No commitment, no pressure. Comfy clothes + water — we got the rest.',
  ctaHref = '/trial/',
  ctaLabel = 'Claim Your Free 2-Week Trial',
} = Astro.props;
---

<section class="bg-brand-red text-white">
  <div class="container-page py-16 md:py-20 text-center">
    <h2 class="font-display text-4xl md:text-6xl mb-4">{headline}</h2>
    <p class="text-lg md:text-xl text-white/90 mb-8 max-w-2xl mx-auto">{sub}</p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={ctaHref} class="bg-white text-brand-red font-bold uppercase tracking-wider px-8 py-4 rounded-md hover:bg-brand-cream transition-colors">{ctaLabel}</a>
      <a href="tel:+19086412769" class="border-2 border-white text-white font-bold uppercase tracking-wider px-8 py-4 rounded-md hover:bg-white hover:text-brand-red transition-colors">📞 (908) 641-2769</a>
    </div>
  </div>
</section>
